# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_REST_PATH=/rest/restaurant/v1

# Database Configuration (for direct access if needed)
DATABASE_URL=postgresql://username:password@host:port/database

# Service Role Key (KEEP SECRET - for server-side operations only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Security Notes:
# 1. Never commit .env.local to version control
# 2. Rotate all keys if they've been exposed
# 3. Use different keys for development/production
# 4. Consider using a secrets manager for production